# MCPwner Environment Variables
# Copy this to .env if you need to override docker-compose defaults



# Note: Service URLs are configured in docker-compose.yaml
# No need to set individual service ports here

# Define the tools you want to enable as a comma-separated list of profiles.
# You can enable whole categories (sast, sca, secrets, reconnaissance, dast, utilities, iac, fuzzing, poc)
# Or you can enable specific tools individually (e.g., semgrep, bandit, codeql, poc-sandbox)
# To opt out of a single tool, omit its category and list the other tools you want.
# The 'poc' profile brings up the poc-sandbox exploit oracle that powers "no exploit, no
# report" - enable it when proving logic/authz/race/BOLA bugs with a scripted PoC.
COMPOSE_PROFILES=sast,fuzzing,dast,sca,secrets,reconnaissance,iac,poc
