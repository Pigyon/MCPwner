# MCPwner Configuration Example
# Copy this file to config.yaml and adjust settings as needed

# MCP Transport Configuration
transport:
  # Transport type: stdio (default) or sse
  # stdio: For local usage with Claude Desktop, Cline, etc.
  #        Containers spawn on-demand via docker run
  # sse:   For deployed/remote usage with web clients
  #        Runs persistent HTTP server
  type: "stdio"

# Server settings
server:
  # Port for MCP SSE transport
  port: 13370
  # Host to bind to (0.0.0.0 for all interfaces)
  host: "0.0.0.0"

# CodeQL Service
codeql:
  # CodeQL service URL (internal Docker network)
  service_url: "http://codeql:8080"

# Linguist Service
linguist:
  # Linguist service URL (internal Docker network)
  service_url: "http://linguist:8081"

# Semgrep Service
semgrep:
  # Semgrep service URL (internal Docker network)
  service_url: "http://semgrep:8082"

# Bandit Service
bandit:
  # Bandit service URL (internal Docker network)
  service_url: "http://bandit:8083"

# Gosec Service
gosec:
  # Gosec service URL (internal Docker network)
  service_url: "http://gosec:8084"

# Brakeman Service
brakeman:
  # Brakeman service URL (internal Docker network)
  service_url: "http://brakeman:8085"

# PMD Service
pmd:
  # PMD service URL (internal Docker network)
  service_url: "http://pmd:8086"

# Psalm Service
psalm:
  # Psalm service URL (internal Docker network)
  service_url: "http://psalm:8087"

# NodeJsScan Service
nodejsscan:
  # NodeJsScan service URL (internal Docker network)
  service_url: "http://nodejsscan:8088"

# Joern Service
joern:
  # Joern service URL (internal Docker network)
  service_url: "http://joern:8089"

# Workspace settings
workspace:
  # Maximum number of concurrent workspaces
  max_workspaces: 10
  # Auto-cleanup workspaces after this many seconds (0 = disabled)
  auto_cleanup_seconds: 3600

# Resource limits
resources:
  # Maximum disk space per workspace in MB
  max_disk_mb: 5000
  # Maximum memory for CodeQL operations in MB
  max_memory_mb: 4096
  # Maximum CPU cores for CodeQL operations
  max_cpu_cores: 2

# Logging
logging:
  # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: "INFO"
  # Log file path
  file: "/var/log/mcpwner/server.log"

# Reconnaissance Services
reconnaissance:
  bbot:
    service_url: "http://bbot:8118"
  httpx:
    service_url: "http://httpx:8112"
  katana:
    service_url: "http://katana:8113"
  gau:
    service_url: "http://gau:8115"
  arjun:
    service_url: "http://arjun:8119"
  wafw00f:
    service_url: "http://wafw00f:8120"
  kiterunner:
    service_url: "http://kiterunner:8121"
