FROM semgrep/semgrep:latest

# Switch to root for installation
USER root

# Install FastAPI and uvicorn for the HTTP service
RUN python -m pip install --break-system-packages --no-cache-dir fastapi uvicorn

WORKDIR /service

# Copy service files
COPY docker/semgrep_service.py .

# Expose service port
EXPOSE 8082

# Run the FastAPI service with uvicorn
CMD ["python", "-m", "uvicorn", "semgrep_service:app", "--host", "0.0.0.0", "--port", "8082"]
